<?php
$cfg_dir = "/boot/config/plugins/PlayniteNASyncUnraidPlugin";
$cfg_file = "$cfg_dir/settings.cfg";
$script_output = '';

// Create config directory if needed
if (!is_dir($cfg_dir)) {
    @mkdir($cfg_dir, 0755, true);
}

// Load existing settings
$settings = [
    'password' => '',
    'share1' => '',
    'share2' => '',
    'enabled' => 'no'
];

if (file_exists($cfg_file)) {
    $loaded = parse_ini_file($cfg_file);
    $settings = array_merge($settings, $loaded);
}

$message = '';
$msg_type = '';

// Handle form submission
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (isset($_POST['action'])) {
        if ($_POST['action'] === 'save') {
            $settings['password'] = $_POST['password'] ?? '';
            $settings['share1'] = $_POST['share1'] ?? '';
            $settings['share2'] = $_POST['share2'] ?? '';
            $settings['enabled'] = $_POST['enabled'] ?? 'no';
            
            // Save to INI file
            $ini_content = "";
            foreach ($settings as $key => $value) {
                $ini_content .= $key . " = \"" . str_replace('"', '\\"', $value) . "\"\n";
            }
            
            if (file_put_contents($cfg_file, $ini_content) !== false) {
                @chmod($cfg_file, 0600);
                $message = 'Settings saved successfully!';
                $msg_type = 'success';
            } else {
                $message = 'Error saving settings!';
                $msg_type = 'error';
            }
        } elseif ($_POST['action'] === 'execute') {
            // Execute bash script
            $script = '/usr/local/emhttp/plugins/PlayniteNASyncUnraidPlugin/scripts/sync.sh';
            if (file_exists($script)) {
                // Make sure script is executable
                @chmod($script, 0755);
                $output = shell_exec('bash ' . escapeshellarg($script) . ' 2>&1');
                if ($output === null) {
                    $script_output = "Error: Unable to execute script. Check permissions.";
                    $message = 'Script execution failed!';
                    $msg_type = 'error';
                } else {
                    $script_output = $output;
                    $message = 'Script executed successfully!';
                    $msg_type = 'success';
                }
            } else {
                $message = 'Script not found at: ' . $script;
                $msg_type = 'error';
            }
        }
    }
}
?>

