Menu="PlayniteNASyncUnraidPlugin"
Icon="cogs"
Title="Settings"
Type="xmenu"
---
<?php
$cfg_file = "/boot/config/plugins/PlayniteNASyncUnraidPlugin/settings.cfg";
if (!is_dir(dirname($cfg_file))) {
    @mkdir(dirname($cfg_file), 0755, true);
}
$current_share = '';
$current_password = '';
if (file_exists($cfg_file)) {
    $plugin_config = parse_ini_file($cfg_file);
    $current_share = $plugin_config['TARGET_SHARE'] ?? '';
    $current_password = $plugin_config['PASSWORD'] ?? '';
}
$message = '';
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $target_share = trim($_POST['target_share'] ?? '');
    $password = trim($_POST['password'] ?? '');
    $data = "TARGET_SHARE=\"" . str_replace('"', '\\"', $target_share) . "\"\n";
    $data .= "PASSWORD=\"" . str_replace('"', '\\"', $password) . "\"\n";
    if (file_put_contents($cfg_file, $data, LOCK_EX) !== false) {
        @chmod($cfg_file, 0600);
        $message = 'Settings saved.';
    } else {
        $message = 'Failed to save settings.';
    }
    $current_share = $target_share;
    $current_password = $password;
}
?>
<h2>Playnite NASync</h2>
<?php if ($message): ?>
    <div class="alert"><?= htmlspecialchars($message, ENT_QUOTES) ?></div>
<?php endif; ?>
<form method="POST">
    <label>Target Share:</label>
    <input type="text" name="target_share" value="<?= htmlspecialchars($current_share, ENT_QUOTES) ?>">
    <label>Password:</label>
    <input type="password" name="password" value="<?= htmlspecialchars($current_password, ENT_QUOTES) ?>">
    <input type="submit" value="Apply">
</form>