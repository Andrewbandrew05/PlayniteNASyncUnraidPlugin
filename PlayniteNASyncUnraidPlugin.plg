<?xml version="1.0" encoding="utf-8"?>
<PLUGIN name="PlayniteNASyncUnraidPlugin" author="Andrew" version="2026.06.24" pluginURL="https://raw.githubusercontent.com/Andrewbandrew05/PlayniteNASyncUnraidPlugin/main/PlayniteNASyncUnraidPlugin.plg" min="6.9.0">

<SHORTDESC>Mark 1 configuration panel for Playnite storage synchronization.</SHORTDESC>

<FILE Name="/tmp/PlayniteNASyncUnraidPlugin.txz" Run="upgradepkg --install-new">
  <URL>https://github.com/Andrewbandrew05/PlayniteNASyncUnraidPlugin/raw/main/archive/PlayniteNASyncUnraidPlugin.txz</URL>
</FILE>

<POSTINSTALL>
<INLINE>
mkdir -p /boot/config/plugins/PlayniteNASyncUnraidPlugin
</INLINE>
</POSTINSTALL>

<FILE Method="remove">
<INLINE>
rm -rf /usr/local/emhttp/plugins/PlayniteNASyncUnraidPlugin
rm -f /tmp/PlayniteNASyncUnraidPlugin.txz
</INLINE>
</FILE>

</PLUGIN>